<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;1,400&family=Inter:wght@400;500&family=Montserrat:wght@500;600&family=Playfair+Display:wght@400;600&display=swap" rel="stylesheet">

  <style>
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-primary-foreground: {{ settings.color_primary_foreground }};
      --color-background: {{ settings.color_background }};
      --color-foreground: {{ settings.color_foreground }};
      --color-muted-foreground: {{ settings.color_muted_foreground }};
      --color-border: {{ settings.color_border }};
      --font-display: "Playfair Display", serif;
      --font-sans: "Inter", sans-serif;
      --font-label: "Montserrat", sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--font-sans);
      background: var(--color-background);
      color: var(--color-foreground);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
      -webkit-font-smoothing: antialiased;
    }
    .password-page {
      max-width: 520px;
      text-align: center;
    }
    .password-page__logo {
      font-family: var(--font-display);
      font-size: 36px;
      letter-spacing: -0.02em;
      margin-bottom: 40px;
    }
    .password-page__heading {
      font-family: var(--font-display);
      font-size: 28px;
      letter-spacing: -0.02em;
      margin-bottom: 16px;
    }
    .password-page__message {
      color: var(--color-muted-foreground);
      line-height: 1.625;
      margin-bottom: 32px;
    }
    .password-page__form {
      display: flex;
      gap: 0;
      margin-bottom: 24px;
    }
    .password-page__input {
      flex: 1;
      border: 1px solid var(--color-border);
      padding: 14px 16px;
      font-family: var(--font-sans);
      font-size: 14px;
      outline: none;
    }
    .password-page__input:focus {
      border-color: var(--color-primary);
    }
    .password-page__submit {
      font-family: var(--font-label);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      background: var(--color-foreground);
      color: var(--color-background);
      border: none;
      padding: 14px 24px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .password-page__submit:hover {
      background: var(--color-primary);
    }
    .password-page__footer {
      color: var(--color-muted-foreground);
      font-size: 13px;
    }
    .password-page__footer a {
      color: var(--color-primary);
      text-decoration: none;
    }
    .password-page__footer a:hover {
      text-decoration: underline;
    }
  </style>

  {{ content_for_header }}
</head>
<body>
  <div class="password-page">
    <div class="password-page__logo">{{ shop.name }}</div>

    {{ content_for_layout }}

    <div class="password-page__footer">
      <p>{{ powered_by_link }}</p>
    </div>
  </div>
</body>
</html>
