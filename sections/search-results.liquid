{%- comment -%} Search Results — Full search page {%- endcomment -%}

{%- paginate search.results by 12 -%}
<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="search-results__header">
      <h1 class="search-results__title">
        {%- if search.performed -%}
          {{ 'general.search_results_for' | t | default: 'Search results for' }} "{{ search.terms }}"
        {%- else -%}
          {{ section.settings.heading | default: 'Search' }}
        {%- endif -%}
      </h1>
      {%- if search.performed -%}
        <p class="search-results__count">{{ search.results_count }} {{ 'general.results' | t | default: 'results' }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Search Form {%- endcomment -%}
    <form action="{{ routes.search_url }}" method="get" role="search" style="margin-bottom: 40px;">
      <div style="display: flex; gap: 0; max-width: 600px;">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search_placeholder' | t | default: 'Search products...' }}" class="form-input" style="flex: 1;">
        <button type="submit" class="btn btn--primary" style="white-space: nowrap;">{{ 'general.search' | t | default: 'Search' }}</button>
      </div>
      <input type="hidden" name="type" value="product">
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <div class="product-grid" data-reveal-stagger>
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item, lazy: true %}
            {%- elsif item.object_type == 'article' -%}
              <a href="{{ item.url }}" class="blog-card">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 400 }}" alt="{{ item.title | escape }}" loading="lazy" class="blog-card__image">
                {%- endif -%}
                <h3 class="blog-card__title">{{ item.title }}</h3>
                <p class="blog-card__excerpt">{{ item.content | strip_html | truncatewords: 20 }}</p>
              </a>
            {%- elsif item.object_type == 'page' -%}
              <a href="{{ item.url }}" style="padding: 24px; border: 1px solid var(--color-border);">
                <h3 style="font-family: var(--font-display); font-size: 18px; margin-bottom: 8px;">{{ item.title }}</h3>
                <p class="text-muted text-body-sm">{{ item.content | strip_html | truncatewords: 20 }}</p>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
        {% render 'pagination', paginate: paginate %}
      {%- else -%}
        <div style="text-align: center; padding: 60px 20px;">
          <p class="heading-sm" style="margin-bottom: 12px;">{{ section.settings.no_results_text | default: 'No results found' }}</p>
          <p class="text-muted" style="margin-bottom: 24px;">{{ 'general.try_different_search' | t | default: 'Try a different search term or browse our collections.' }}</p>
          {% render 'button', label: 'Shop All', url: '/collections/all', style: 'primary', icon: 'arrow' %}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>
{%- endpaginate -%}

{% schema %}
{
  "name": "Search Results",
  "tag": "section",
  "class": "search-results-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Search" },
    { "type": "text", "id": "no_results_text", "label": "No results text", "default": "No results found" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [{ "name": "Search Results" }]
}
{% endschema %}
