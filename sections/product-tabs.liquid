{%- comment -%} Product Tabs — Tab/accordion content for product details {%- endcomment -%}

<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; border-top: 1px solid var(--color-border);" data-reveal>
  <div class="page-width" style="max-width: 900px;">
    {%- comment -%} Desktop Tabs {%- endcomment -%}
    <div class="product-tabs__desktop">
      <div class="product-tabs__nav" role="tablist">
        {%- for block in section.blocks -%}
          <button
            type="button"
            role="tab"
            class="product-tabs__tab{% if forloop.first %} is-active{% endif %}"
            data-tab-trigger
            data-tab-index="{{ forloop.index0 }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            {{ block.shopify_attributes }}
          >{{ block.settings.heading }}</button>
        {%- endfor -%}
      </div>
      {%- for block in section.blocks -%}
        <div class="product-tabs__panel{% if forloop.first %} is-active{% endif %}" data-tab-panel data-tab-index="{{ forloop.index0 }}" role="tabpanel">
          <div class="product-tabs__content">{{ block.settings.content }}</div>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} Mobile Accordion {%- endcomment -%}
    <div class="product-tabs__mobile accordion" data-accordion>
      {%- for block in section.blocks -%}
        <div class="accordion__item{% if forloop.first %} is-open{% endif %}" data-accordion-item {{ block.shopify_attributes }}>
          <button type="button" class="accordion__trigger" data-accordion-trigger>
            <span>{{ block.settings.heading }}</span>
            <span class="accordion__trigger-icon">{% render 'icon', name: 'chevron-down' %}</span>
          </button>
          <div class="accordion__content"{% if forloop.first %} style="max-height: 1000px;"{% endif %}>
            <div class="accordion__body">{{ block.settings.content }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .product-tabs__desktop { display: none; }
  .product-tabs__nav { display: flex; border-bottom: 1px solid var(--color-border); gap: 0; margin-bottom: 32px; }
  .product-tabs__tab { font-family: var(--font-label); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; padding: 16px 24px; border: none; background: none; cursor: pointer; color: var(--color-muted-foreground); border-bottom: 2px solid transparent; transition: color 0.2s, border-color 0.2s; }
  .product-tabs__tab.is-active { color: var(--color-foreground); border-bottom-color: var(--color-primary); }
  .product-tabs__tab:hover { color: var(--color-foreground); }
  .product-tabs__panel { display: none; }
  .product-tabs__panel.is-active { display: block; }
  .product-tabs__content { line-height: 1.8; color: var(--color-muted-foreground); }
  .product-tabs__content p { margin-bottom: 16px; }
  @media (min-width: 768px) {
    .product-tabs__desktop { display: block; }
    .product-tabs__mobile { display: none; }
  }
</style>

{% schema %}
{
  "name": "Product Tabs",
  "tag": "section",
  "class": "product-tabs-section",
  "settings": [
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 60 }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        { "type": "text", "id": "heading", "label": "Tab heading", "default": "Description" },
        { "type": "richtext", "id": "content", "label": "Tab content", "default": "<p>Product details and description content.</p>" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Product Tabs",
      "blocks": [
        { "type": "tab", "settings": { "heading": "Description", "content": "<p>Full product description with all the details.</p>" } },
        { "type": "tab", "settings": { "heading": "Key Ingredients", "content": "<p>A curated blend of premium ingredients for optimal results.</p>" } },
        { "type": "tab", "settings": { "heading": "How to Apply", "content": "<p>Step-by-step application guide for best results.</p>" } }
      ]
    }
  ]
}
{% endschema %}
