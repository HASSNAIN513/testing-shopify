{%- comment -%} Editorial Banner Section {%- endcomment -%}

<section style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div style="display:grid;grid-template-columns:1fr;gap:40px;">
      <div style="overflow:hidden;">
        {%- if section.settings.image -%}
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" style="width:100%;aspect-ratio:4/5;object-fit:cover;">
        {%- else -%}
          <div style="aspect-ratio:4/5;background:var(--color-accent);"></div>
        {%- endif -%}
      </div>
      <div style="background:var(--color-accent);padding:40px;">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="heading-lg" style="margin-top:16px;">
          {{ section.settings.heading }}
          {%- if section.settings.heading_accent != blank -%}
            <em class="heading-accent">{{ section.settings.heading_accent }}</em>
          {%- endif -%}
        </h2>
        {%- if section.settings.body != blank -%}
          <div style="color:var(--color-muted-foreground);margin-top:20px;line-height:1.625;">{{ section.settings.body }}</div>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url | default: '#' }}" style="display:inline-block;margin-top:24px;font-family:var(--font-label);font-size:12px;letter-spacing:0.12em;text-transform:uppercase;border-bottom:1px solid currentColor;padding-bottom:2px;">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 1024px) {
    section .page-width > div[style*="grid-template-columns: 1fr"] { grid-template-columns: 1fr 1.1fr !important; gap: 64px; }
  }
</style>

{% schema %}
{
  "name": "Editorial Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beauty That" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent", "default": "Inspires" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>We believe beauty should be effortless, ethical, and empowering.</p>" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Learn More" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ]
}
{% endschema %}
