{%- comment -%} Editorial Banner — Two-column editorial story layout {%- endcomment -%}

<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;" data-reveal>
  <div class="page-width">
    <div class="editorial__grid">
      <div class="editorial__image-col">
        {%- if section.settings.image -%}
          <div style="overflow: hidden;">
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              srcset="{{ section.settings.image | image_url: width: 400 }} 400w, {{ section.settings.image | image_url: width: 600 }} 600w, {{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1000 }} 1000w"
              sizes="(min-width: 1024px) 45vw, 100vw"
              alt="{{ section.settings.heading | escape }}"
              loading="lazy"
              class="editorial__image"
            >
          </div>
        {%- endif -%}
      </div>
      <div class="editorial__content-col">
        <div class="editorial__content" style="background-color: {{ section.settings.content_bg_color }};">
          {%- if section.settings.eyebrow != blank -%}
            <p class="eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}
          <h2 class="editorial__heading">
            {{ section.settings.heading }}
            {%- if section.settings.heading_accent != blank -%}
              <em class="heading-accent">{{ section.settings.heading_accent }}</em>
            {%- endif -%}
          </h2>
          {%- if section.settings.body != blank -%}
            <div class="editorial__body text-muted" style="margin-top: 20px; line-height: 1.625;">
              {{ section.settings.body }}
            </div>
          {%- endif -%}
          {%- if section.settings.cta_label != blank -%}
            <a href="{{ section.settings.cta_url }}" class="editorial__cta" style="margin-top: 32px;">
              <span>{{ section.settings.cta_label }}</span>
              <span class="btn__icon btn__icon--arrow">{% render 'icon', name: 'arrow-up-right' %}</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .editorial__grid { display: grid; grid-template-columns: 1fr; gap: 40px; }
  .editorial__image { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; transition: transform 0.7s ease-out; }
  .editorial__image:hover { transform: scale(1.05); }
  .editorial__content { padding: 40px 32px; display: flex; flex-direction: column; justify-content: center; height: 100%; }
  .editorial__heading { font-family: var(--font-display); font-size: 36px; letter-spacing: -0.02em; line-height: 0.98; }
  .editorial__cta { display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-label); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; padding-bottom: 4px; border-bottom: 1px solid var(--color-foreground); transition: color 0.2s, border-color 0.2s; }
  .editorial__cta:hover { color: var(--color-primary); border-color: var(--color-primary); }
  .editorial__cta svg { width: 14px; height: 14px; transition: transform 0.2s; }
  .editorial__cta:hover svg { transform: translate(2px, -2px); }

  @media (min-width: 1024px) {
    .editorial__grid { grid-template-columns: 1fr 1.1fr; gap: 64px; }
    .editorial__heading { font-size: 64px; }
    .editorial__content { padding: 60px 48px; }
  }
</style>

{% schema %}
{
  "name": "Editorial Banner",
  "tag": "section",
  "class": "editorial-section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beauty That Tells" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "a Story" },
    { "type": "richtext", "id": "body", "label": "Body text", "default": "<p>Every IYMNN BEAUTY product is crafted with intention — blending modern luxury with clean, conscious beauty. Our formulas celebrate all skin tones and hair textures.</p>" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Read the story" },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "color", "id": "content_bg_color", "label": "Content background color", "default": "#F5E8E6" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [{ "name": "Editorial Banner" }]
}
{% endschema %}
