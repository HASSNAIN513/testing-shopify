{%- comment -%} Hero Section — Full homepage hero with 2-column layout {%- endcomment -%}

<section
  class="hero-section"
  style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
  data-reveal
>
  <div class="page-width">
    <div class="hero__grid">
      {%- comment -%} Left Column: Image {%- endcomment -%}
      <div class="hero__image-col">
        <div class="hero__image-wrap">
          {%- if section.settings.image -%}
            <img
              src="{{ section.settings.image | image_url: width: 800 }}"
              srcset="
                {{ section.settings.image | image_url: width: 400 }} 400w,
                {{ section.settings.image | image_url: width: 600 }} 600w,
                {{ section.settings.image | image_url: width: 800 }} 800w,
                {{ section.settings.image | image_url: width: 1000 }} 1000w,
                {{ section.settings.image | image_url: width: 1200 }} 1200w
              "
              sizes="(min-width: 1024px) 50vw, 100vw"
              alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
              loading="eager"
              fetchpriority="high"
              class="hero__image"
            >
          {%- endif -%}
          {%- comment -%} Decorative Letter {%- endcomment -%}
          {%- if section.settings.decorative_letter != blank -%}
            <span class="hero__decorative-letter" aria-hidden="true">{{ section.settings.decorative_letter }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Right Column: Content {%- endcomment -%}
      <div class="hero__content-col">
        <div class="hero__content">
          {%- if section.settings.eyebrow != blank -%}
            <p class="eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          <h1 class="hero__heading heading-xl">
            {{ section.settings.heading }}
            {%- if section.settings.heading_accent != blank -%}
              <em class="heading-accent">{{ section.settings.heading_accent }}</em>
            {%- endif -%}
          </h1>

          {%- if section.settings.body != blank -%}
            <div class="hero__body text-muted" style="max-width: 448px; margin-top: 20px; line-height: 1.625;">
              {{ section.settings.body }}
            </div>
          {%- endif -%}

          {%- comment -%} CTA Buttons {%- endcomment -%}
          <div class="hero__actions" style="display: flex; gap: 12px; margin-top: 32px; flex-wrap: wrap;">
            {%- if section.settings.cta1_label != blank -%}
              {% render 'button', label: section.settings.cta1_label, url: section.settings.cta1_url, style: 'primary', icon: 'arrow' %}
            {%- endif -%}
            {%- if section.settings.cta2_label != blank -%}
              {% render 'button', label: section.settings.cta2_label, url: section.settings.cta2_url, style: 'outline', icon: 'arrow' %}
            {%- endif -%}
          </div>

          {%- comment -%} Featured Product Overlay {%- endcomment -%}
          {%- if section.settings.featured_product != blank -%}
            {%- assign fp = section.settings.featured_product -%}
            <div class="hero__featured-product">
              {%- if fp.featured_image -%}
                <img src="{{ fp.featured_image | image_url: width: 100 }}" alt="{{ fp.title | escape }}" loading="eager" class="hero__featured-image">
              {%- endif -%}
              <div class="hero__featured-info">
                <p class="hero__featured-label font-label" style="font-size: 9px; color: var(--color-muted-foreground);">{{ 'products.featured' | t | default: 'Featured' }}</p>
                <p style="font-family: var(--font-display); font-size: 14px;">{{ fp.title }}</p>
                <p style="font-family: var(--font-display); font-size: 14px; color: var(--color-primary);">{{ fp.price | money }}</p>
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Stats Bar {%- endcomment -%}
          {%- if section.blocks.size > 0 -%}
            <div class="hero__stats" style="display: flex; gap: 32px; margin-top: 40px; padding-top: 32px; border-top: 1px solid var(--color-border);">
              {%- for block in section.blocks -%}
                <div class="hero__stat" {{ block.shopify_attributes }}>
                  <p style="font-family: var(--font-display); font-size: 30px; letter-spacing: -0.02em;">{{ block.settings.value }}</p>
                  <p class="font-label" style="font-size: 10px; color: var(--color-muted-foreground); margin-top: 4px;">{{ block.settings.label }}</p>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .hero__image-wrap {
    position: relative;
    overflow: hidden;
  }
  .hero__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }
  .hero__decorative-letter {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-serif-editorial);
    font-style: italic;
    font-size: 120px;
    color: var(--color-primary);
    opacity: 0.2;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
  }
  .hero__featured-product {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    padding: 12px 16px;
    margin-top: 32px;
    max-width: fit-content;
  }
  .hero__featured-image {
    width: 48px;
    height: 60px;
    object-fit: cover;
  }

  @media (min-width: 1024px) {
    .hero__grid {
      grid-template-columns: 1.05fr 1fr;
      gap: 64px;
    }
    .hero__decorative-letter {
      font-size: 200px;
    }
  }
</style>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-section-wrap",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "decorative_letter",
      "label": "Decorative letter",
      "default": "G",
      "info": "Large watermark letter overlaying the image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Premium Beauty"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Effortless Beauty,"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent (italic)",
      "default": "Redefined.",
      "info": "Displayed in italic serif font in brand color"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Premium hair extensions and lip kits crafted for the modern woman. Discover luxury beauty that moves with you.</p>"
    },
    {
      "type": "text",
      "id": "cta1_label",
      "label": "Primary button label",
      "default": "Shop Extensions"
    },
    {
      "type": "url",
      "id": "cta1_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta2_label",
      "label": "Secondary button label",
      "default": "Shop Lip Kits"
    },
    {
      "type": "url",
      "id": "cta2_url",
      "label": "Secondary button link"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FBF0ED"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 150,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 150,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "200k+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Happy customers"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "200k+", "label": "Happy customers" } },
        { "type": "stat", "settings": { "value": "4.9★", "label": "Average rating" } },
        { "type": "stat", "settings": { "value": "100%", "label": "Clean beauty" } }
      ]
    }
  ]
}
{% endschema %}
