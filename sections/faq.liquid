{%- comment -%} FAQ — Two-column layout with accordion {%- endcomment -%}

<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; border-top: 1px solid var(--color-border);" data-reveal>
  <div class="page-width" style="max-width: 1100px;">
    <div class="faq__grid">
      <div class="faq__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="heading-lg">
          {{ section.settings.heading }}
          {%- if section.settings.heading_accent != blank -%}
            <em class="heading-accent">{{ section.settings.heading_accent }}</em>
          {%- endif -%}
        </h2>
        {%- if section.settings.body != blank -%}
          <p class="text-muted" style="margin-top: 16px; line-height: 1.625;">{{ section.settings.body }}</p>
        {%- endif -%}
      </div>

      <div class="accordion" data-accordion>
        {%- for block in section.blocks -%}
          <div class="accordion__item" data-accordion-item {{ block.shopify_attributes }}>
            <button type="button" class="accordion__trigger" data-accordion-trigger aria-expanded="false" aria-controls="faq-content-{{ section.id }}-{{ forloop.index }}">
              <span>{{ block.settings.question }}</span>
              <span class="accordion__trigger-icon">{% render 'icon', name: 'chevron-down' %}</span>
            </button>
            <div class="accordion__content" id="faq-content-{{ section.id }}-{{ forloop.index }}" role="region">
              <div class="accordion__body">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  .faq__grid { display: grid; grid-template-columns: 1fr; gap: 40px; }
  @media (min-width: 1024px) {
    .faq__grid { grid-template-columns: 1fr 1.4fr; gap: 64px; }
  }
</style>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "class": "faq-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Support" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "Questions" },
    { "type": "text", "id": "body", "label": "Description", "default": "Everything you need to know about our products and policies." },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What are the extensions made from?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Our extensions are made from 100% Remy human hair, ethically sourced and carefully processed to maintain natural texture, shine, and longevity.</p>" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "What are the extensions made from?", "answer": "<p>Our extensions are made from 100% Remy human hair, ethically sourced and carefully processed to maintain natural texture, shine, and longevity.</p>" } },
        { "type": "faq_item", "settings": { "question": "How long do the lip kits last?", "answer": "<p>Our matte lip kits last up to 8 hours with a single application. The gloss formulas provide 4-6 hours of wear with a comfortable, non-sticky finish.</p>" } },
        { "type": "faq_item", "settings": { "question": "Do you offer international shipping?", "answer": "<p>Yes, we ship worldwide. Standard international shipping takes 7-14 business days. Express options are available at checkout.</p>" } },
        { "type": "faq_item", "settings": { "question": "What is your return policy?", "answer": "<p>We offer a 30-day satisfaction guarantee. If you're not completely happy with your purchase, return it in its original condition for a full refund.</p>" } }
      ]
    }
  ]
}
{% endschema %}
