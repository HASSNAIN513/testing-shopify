{%- comment -%} FAQ Section {%- endcomment -%}

<section style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div style="display:grid;grid-template-columns:1fr;gap:40px;">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="heading-lg" style="margin-top:16px;">
          {{ section.settings.heading }}
          {%- if section.settings.heading_accent != blank -%}
            <em class="heading-accent">{{ section.settings.heading_accent }}</em>
          {%- endif -%}
        </h2>
      </div>
      <div>
        {%- for block in section.blocks -%}
          <details {{ block.shopify_attributes }} style="border-top:1px solid var(--color-border);padding:20px 0;">
            <summary style="font-family:var(--font-display);font-size:18px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;">
              {{ block.settings.question }}
              <span style="font-size:20px;transition:transform 0.3s;">+</span>
            </summary>
            <div style="color:var(--color-muted-foreground);margin-top:12px;line-height:1.625;font-size:15px;">
              {{ block.settings.answer }}
            </div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  details[open] summary span { transform: rotate(45deg); }
  @media (min-width: 1024px) {
    section .page-width > div[style*="grid-template-columns: 1fr"] { grid-template-columns: 1fr 1.4fr !important; gap: 64px; }
  }
</style>

{% schema %}
{
  "name": "FAQ",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Common" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent", "default": "Questions" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What are your extensions made of?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Our extensions are made from 100% Remy human hair, ethically sourced and carefully processed.</p>" }
      ]
    }
  ],
  "max_blocks": 20
}
{% endschema %}
