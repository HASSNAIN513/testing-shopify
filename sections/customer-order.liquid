{%- comment -%} Customer Order Detail {%- endcomment -%}

<section class="account-dashboard">
  <a href="{{ routes.account_url }}" style="display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-label); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 24px; color: var(--color-muted-foreground);">← {{ 'customer.back_to_account' | t | default: 'Back to Account' }}</a>

  <h1 class="account-dashboard__title">{{ order.name }}</h1>
  <p class="text-muted" style="margin-bottom: 32px;">{{ 'customer.placed_on' | t | default: 'Placed on' }} {{ order.created_at | date: '%B %d, %Y' }}</p>

  <div style="overflow-x: auto; margin-bottom: 40px;">
    <table class="order-table">
      <thead>
        <tr>
          <th>{{ 'customer.product' | t | default: 'Product' }}</th>
          <th>{{ 'customer.sku' | t | default: 'SKU' }}</th>
          <th>{{ 'customer.price' | t | default: 'Price' }}</th>
          <th>{{ 'customer.quantity' | t | default: 'Qty' }}</th>
          <th style="text-align: right;">{{ 'customer.total' | t | default: 'Total' }}</th>
        </tr>
      </thead>
      <tbody>
        {%- for line_item in order.line_items -%}
          <tr>
            <td>
              <p style="font-family: var(--font-display);">{{ line_item.title }}</p>
              {%- unless line_item.variant.title == 'Default Title' -%}
                <p style="font-size: 13px; color: var(--color-muted-foreground);">{{ line_item.variant.title }}</p>
              {%- endunless -%}
            </td>
            <td style="font-size: 13px;">{{ line_item.sku }}</td>
            <td>{{ line_item.original_price | money }}</td>
            <td>{{ line_item.quantity }}</td>
            <td style="text-align: right; font-family: var(--font-display);">{{ line_item.final_line_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 32px;">
    <div>
      <h3 class="font-label" style="font-size: 10px; margin-bottom: 12px;">{{ 'customer.shipping_address' | t | default: 'Shipping Address' }}</h3>
      <p style="font-size: 14px; color: var(--color-muted-foreground); line-height: 1.625;">{{ order.shipping_address | format_address }}</p>
    </div>
    <div>
      <h3 class="font-label" style="font-size: 10px; margin-bottom: 12px;">{{ 'customer.billing_address' | t | default: 'Billing Address' }}</h3>
      <p style="font-size: 14px; color: var(--color-muted-foreground); line-height: 1.625;">{{ order.billing_address | format_address }}</p>
    </div>
    <div>
      <h3 class="font-label" style="font-size: 10px; margin-bottom: 12px;">{{ 'customer.order_summary' | t | default: 'Summary' }}</h3>
      <div style="font-size: 14px;">
        <div style="display: flex; justify-content: space-between; margin-bottom: 4px;"><span>Subtotal</span><span>{{ order.line_items_subtotal_price | money }}</span></div>
        {%- for shipping_method in order.shipping_methods -%}
          <div style="display: flex; justify-content: space-between; margin-bottom: 4px;"><span>Shipping ({{ shipping_method.title }})</span><span>{{ shipping_method.price | money }}</span></div>
        {%- endfor -%}
        <div style="display: flex; justify-content: space-between; margin-bottom: 4px;"><span>Tax</span><span>{{ order.tax_price | money }}</span></div>
        <div style="display: flex; justify-content: space-between; font-family: var(--font-display); font-size: 18px; padding-top: 8px; border-top: 1px solid var(--color-border); margin-top: 8px;"><span>Total</span><span>{{ order.total_price | money }}</span></div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{ "name": "Customer Order", "tag": "section", "settings": [], "presets": [{ "name": "Customer Order" }] }
{% endschema %}
