{%- comment -%} Customer Register {%- endcomment -%}

<section class="customer-page">
  <h1 class="customer-page__title">{{ 'customer.create_account' | t | default: 'Create Account' }}</h1>
  <p class="customer-page__subtitle">{{ 'customer.register_subtitle' | t | default: 'Join the IYMNN BEAUTY community.' }}</p>

  {% form 'create_customer' %}
    {%- if form.errors -%}
      <div class="form-error" role="alert" style="margin-bottom: 20px;">{{ form.errors | default_errors }}</div>
    {%- endif -%}
    <div class="customer-page__form">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label class="form-label" for="register-first-name">{{ 'customer.first_name' | t | default: 'First name' }}</label>
          <input type="text" id="register-first-name" name="customer[first_name]" class="form-input" autocomplete="given-name" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="register-last-name">{{ 'customer.last_name' | t | default: 'Last name' }}</label>
          <input type="text" id="register-last-name" name="customer[last_name]" class="form-input" autocomplete="family-name" required>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="register-email">{{ 'customer.email' | t | default: 'Email' }}</label>
        <input type="email" id="register-email" name="customer[email]" class="form-input" autocomplete="email" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="register-password">{{ 'customer.password' | t | default: 'Password' }}</label>
        <input type="password" id="register-password" name="customer[password]" class="form-input" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn btn--primary btn--full">{{ 'customer.create_account' | t | default: 'Create Account' }}</button>
    </div>
  {% endform %}

  <p class="customer-page__link">{{ 'customer.already_have_account' | t | default: 'Already have an account?' }} <a href="{{ routes.account_login_url }}">{{ 'customer.sign_in' | t | default: 'Sign in' }}</a></p>
</section>

{% schema %}
{ "name": "Customer Register", "tag": "section", "settings": [], "presets": [{ "name": "Customer Register" }] }
{% endschema %}
