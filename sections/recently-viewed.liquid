{%- comment -%} Recently Viewed — Populated by JS from localStorage {%- endcomment -%}

<section class="recently-viewed-section" data-recently-viewed data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; display: none;">
  <div class="page-width">
    <h2 class="heading-md" style="margin-bottom: 40px;">{{ section.settings.heading }}</h2>
    <div class="product-grid" data-recently-viewed-grid></div>
  </div>
</section>

{% schema %}
{
  "name": "Recently Viewed",
  "tag": "section",
  "class": "recently-viewed-wrap",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Recently Viewed" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 60 }
  ],
  "presets": [{ "name": "Recently Viewed" }]
}
{% endschema %}
