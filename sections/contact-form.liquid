{%- comment -%} Contact Form — Contact page with form + sidebar {%- endcomment -%}

<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div style="text-align: center; margin-bottom: 48px;" data-reveal>
      <h1 class="heading-lg">{{ section.settings.heading | default: 'Get in Touch' }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="text-muted" style="margin-top: 12px; max-width: 500px; margin-left: auto; margin-right: auto;">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="contact__grid">
      {%- comment -%} Contact Form {%- endcomment -%}
      <div data-reveal>
        {% form 'contact' %}
          {%- if form.posted_successfully? -%}
            <p class="form-success" style="margin-bottom: 24px;" role="status">{{ 'contact.success' | t | default: 'Thank you! We\'ll get back to you within 24 hours.' }}</p>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="form-error" style="margin-bottom: 24px;" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div class="form-group">
              <label class="form-label" for="contact-name">{{ 'contact.name' | t | default: 'Name' }}</label>
              <input type="text" id="contact-name" name="contact[name]" class="form-input" required>
            </div>
            <div class="form-group">
              <label class="form-label" for="contact-email">{{ 'contact.email' | t | default: 'Email' }}</label>
              <input type="email" id="contact-email" name="contact[email]" class="form-input" required>
            </div>
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-subject">{{ 'contact.subject' | t | default: 'Subject' }}</label>
            <select id="contact-subject" name="contact[subject]" class="form-select">
              <option value="General Inquiry">General Inquiry</option>
              <option value="Order Support">Order Support</option>
              <option value="Returns & Exchanges">Returns & Exchanges</option>
              <option value="Wholesale">Wholesale</option>
              <option value="Press & Media">Press & Media</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="contact-message">{{ 'contact.message' | t | default: 'Message' }}</label>
            <textarea id="contact-message" name="contact[body]" class="form-textarea" required></textarea>
          </div>
          <button type="submit" class="btn btn--primary">{{ 'contact.send' | t | default: 'Send Message' }}</button>
        {% endform %}
      </div>

      {%- comment -%} Sidebar {%- endcomment -%}
      <div data-reveal>
        {%- if section.settings.email != blank -%}
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
            <span style="color: var(--color-primary);">{% render 'icon', name: 'mail' %}</span>
            <div>
              <p class="font-label" style="font-size: 10px; margin-bottom: 4px;">{{ 'contact.email_label' | t | default: 'Email' }}</p>
              <a href="mailto:{{ section.settings.email }}" style="font-size: 14px;">{{ section.settings.email }}</a>
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.phone != blank -%}
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
            <span style="color: var(--color-primary);">{% render 'icon', name: 'phone' %}</span>
            <div>
              <p class="font-label" style="font-size: 10px; margin-bottom: 4px;">{{ 'contact.phone_label' | t | default: 'Phone' }}</p>
              <a href="tel:{{ section.settings.phone }}" style="font-size: 14px;">{{ section.settings.phone }}</a>
            </div>
          </div>
        {%- endif -%}
        {%- if section.settings.hours != blank -%}
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 24px;">
            <span style="color: var(--color-primary);">{% render 'icon', name: 'clock' %}</span>
            <div>
              <p class="font-label" style="font-size: 10px; margin-bottom: 4px;">{{ 'contact.hours_label' | t | default: 'Hours' }}</p>
              <p style="font-size: 14px;">{{ section.settings.hours }}</p>
            </div>
          </div>
        {%- endif -%}
        <div style="margin-top: 32px;">
          {% render 'social-links' %}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact__grid { display: grid; grid-template-columns: 1fr; gap: 48px; max-width: 900px; margin: 0 auto; }
  @media (min-width: 768px) { .contact__grid { grid-template-columns: 1.5fr 1fr; } }
</style>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "class": "contact-form-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in Touch" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "We'd love to hear from you. Send us a message and we'll respond within 24 hours." },
    { "type": "text", "id": "email", "label": "Email", "default": "hello@iymmn.com" },
    { "type": "text", "id": "phone", "label": "Phone" },
    { "type": "text", "id": "hours", "label": "Business hours", "default": "Mon-Fri: 9am - 5pm EST" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [{ "name": "Contact Form" }]
}
{% endschema %}
