{%- comment -%} Policy Content — Renders page content with optional sidebar {%- endcomment -%}
<section class="policy-page section-padding">
  {%- if section.settings.show_sidebar -%}
    <aside class="policy-page__sidebar">
      <a href="/policies/privacy-policy" class="policy-page__sidebar-link">Privacy Policy</a>
      <a href="/policies/terms-of-service" class="policy-page__sidebar-link">Terms of Service</a>
      <a href="/policies/shipping-policy" class="policy-page__sidebar-link">Shipping Policy</a>
      <a href="/policies/refund-policy" class="policy-page__sidebar-link">Refund Policy</a>
    </aside>
  {%- endif -%}
  <div class="policy-page__content">
    <h1>{{ page.title }}</h1>
    {%- if section.settings.last_updated != blank -%}
      <p class="policy-page__date">{{ 'general.last_updated' | t | default: 'Last updated:' }} {{ section.settings.last_updated }}</p>
    {%- endif -%}
    {{ page.content }}
  </div>
</section>

{% schema %}
{
  "name": "Policy Content",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "last_updated", "label": "Last updated date" },
    { "type": "checkbox", "id": "show_sidebar", "label": "Show sidebar navigation", "default": true }
  ],
  "presets": [{ "name": "Policy Content" }]
}
{% endschema %}
