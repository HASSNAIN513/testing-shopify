{%- comment -%} CTA Strip — Simple CTA band {%- endcomment -%}
<section style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; padding: 48px 0; text-align: center;" data-reveal>
  <div class="page-width">
    <h2 style="font-family: var(--font-display); font-size: 30px; letter-spacing: -0.02em; margin-bottom: 24px; color: {{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
    {% render 'button', label: section.settings.cta_label, url: section.settings.cta_url, style: 'outline-light', icon: 'arrow' %}
  </div>
</section>
{% schema %}
{
  "name": "CTA Strip",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop the Collection" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop Now" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#1A1714" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" }
  ],
  "presets": [{ "name": "CTA Strip" }]
}
{% endschema %}
