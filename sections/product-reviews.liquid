{%- comment -%} Product Reviews — Native block-based reviews with future app integration hooks {%- endcomment -%}

{%- comment -%}
  REVIEWS APP INTEGRATION:
  To integrate Judge.me, Yotpo, Okendo, or Stamped in the future, replace the
  review cards below with the app's embed widget. Example for Judge.me:
  <div id="judgeme_product_reviews" data-id="{{ product.id }}"></div>
  The rest of the section structure (heading, summary) can remain.
{%- endcomment -%}

<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; border-top: 1px solid var(--color-border);" data-reveal>
  <div class="page-width">
    <div style="text-align: center; margin-bottom: 48px;">
      <h2 class="heading-md">{{ section.settings.heading }}</h2>

      {%- comment -%} Average Rating Summary {%- endcomment -%}
      {%- if section.settings.average_rating > 0 -%}
        <div style="display: flex; align-items: center; justify-content: center; gap: 12px; margin-top: 16px;">
          {% render 'rating-stars', rating: section.settings.average_rating, show_count: false %}
          <span style="font-family: var(--font-display); font-size: 24px;">{{ section.settings.average_rating }}</span>
          <span class="text-muted" style="font-size: 14px;">{{ 'products.based_on' | t | default: 'Based on' }} {{ section.settings.total_reviews }} {{ 'products.reviews' | t | default: 'reviews' }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Rating Breakdown Bars {%- endcomment -%}
    {%- if section.settings.show_breakdown -%}
      <div style="max-width: 400px; margin: 0 auto 48px;">
        {%- for i in (1..5) -%}
          {%- assign star_num = 6 | minus: i -%}
          {%- assign bar_id = 'bar_' | append: star_num | append: '_pct' -%}
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
            <span style="font-size: 13px; width: 20px; text-align: right;">{{ star_num }}★</span>
            <div style="flex: 1; height: 6px; background: var(--color-border); overflow: hidden;">
              <div style="height: 100%; width: {{ section.settings[bar_id] | default: 0 }}%; background: var(--color-primary);"></div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Review Cards {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="reviews-page__grid">
        {%- for block in section.blocks -%}
          <div class="reviews-page__card" {{ block.shopify_attributes }}>
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
              {% render 'rating-stars', rating: block.settings.rating, show_count: false %}
              {%- if block.settings.date != blank -%}
                <span style="font-size: 12px; color: var(--color-muted-foreground);">{{ block.settings.date }}</span>
              {%- endif -%}
            </div>
            <p style="line-height: 1.625; margin-bottom: 16px;">{{ block.settings.body }}</p>
            {%- if block.settings.photo -%}
              <img src="{{ block.settings.photo | image_url: width: 200 }}" alt="Review photo" loading="lazy" style="width: 80px; height: 80px; object-fit: cover; margin-bottom: 16px;">
            {%- endif -%}
            <p class="font-label" style="font-size: 11px;">{{ block.settings.reviewer_name }}</p>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Write a Review CTA {%- endcomment -%}
    <div style="text-align: center; margin-top: 40px;">
      {% render 'button', label: section.settings.write_review_text, tag: 'button', style: 'outline', icon: 'none', type: 'button' %}
    </div>
  </div>
</section>

<style>
  .reviews-page__grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  .reviews-page__card { padding: 24px; border: 1px solid var(--color-border); }
  @media (min-width: 768px) { .reviews-page__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .reviews-page__grid { grid-template-columns: repeat(3, 1fr); } }
</style>

{% schema %}
{
  "name": "Product Reviews",
  "tag": "section",
  "class": "product-reviews-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer Reviews" },
    { "type": "range", "id": "average_rating", "label": "Average rating", "min": 0, "max": 5, "step": 1, "default": 5, "info": "Set to 0 to hide" },
    { "type": "range", "id": "total_reviews", "label": "Total review count", "min": 0, "max": 10000, "step": 1, "default": 124 },
    { "type": "checkbox", "id": "show_breakdown", "label": "Show rating breakdown", "default": true },
    { "type": "range", "id": "bar_5_pct", "label": "5-star percentage", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 82 },
    { "type": "range", "id": "bar_4_pct", "label": "4-star percentage", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 12 },
    { "type": "range", "id": "bar_3_pct", "label": "3-star percentage", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 4 },
    { "type": "range", "id": "bar_2_pct", "label": "2-star percentage", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 1 },
    { "type": "range", "id": "bar_1_pct", "label": "1-star percentage", "min": 0, "max": 100, "step": 1, "unit": "%", "default": 1 },
    { "type": "text", "id": "write_review_text", "label": "Write review button text", "default": "Write a Review" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "reviewer_name", "label": "Reviewer name", "default": "Sarah M." },
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "date", "label": "Date", "default": "2 weeks ago" },
        { "type": "textarea", "id": "body", "label": "Review text", "default": "Absolutely love this product! The quality is outstanding and it blends perfectly." },
        { "type": "image_picker", "id": "photo", "label": "Review photo" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [{ "name": "Product Reviews" }]
}
{% endschema %}
