{%- comment -%} Blog Grid — Blog listing page {%- endcomment -%}

{%- paginate blog.articles by 9 -%}
<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <h1 class="heading-lg" style="margin-bottom: 40px;">{{ section.settings.heading | default: blog.title }}</h1>
    <div class="blog-grid" data-reveal-stagger>
      {%- for article in blog.articles -%}
        <article class="blog-card">
          {%- if article.image -%}
            <a href="{{ article.url }}">
              <img src="{{ article.image | image_url: width: 600 }}" srcset="{{ article.image | image_url: width: 300 }} 300w, {{ article.image | image_url: width: 450 }} 450w, {{ article.image | image_url: width: 600 }} 600w" sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw" alt="{{ article.title | escape }}" loading="lazy" class="blog-card__image">
            </a>
          {%- endif -%}
          {%- if section.settings.show_tags and article.tags.size > 0 -%}
            <p class="blog-card__tag">{{ article.tags.first }}</p>
          {%- endif -%}
          <h2 class="blog-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h2>
          {%- if section.settings.show_date -%}
            <p class="blog-card__meta">{{ article.published_at | date: '%B %d, %Y' }}{% if section.settings.show_author %} · {{ article.author }}{% endif %}</p>
          {%- endif -%}
          {%- if section.settings.show_excerpt and article.excerpt != blank -%}
            <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncatewords: 25 }}</p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
    {% render 'pagination', paginate: paginate %}
  </div>
</section>
{%- endpaginate -%}

{% schema %}
{
  "name": "Blog Grid",
  "tag": "section",
  "class": "blog-grid-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "checkbox", "id": "show_tags", "label": "Show tags", "default": true },
    { "type": "checkbox", "id": "show_date", "label": "Show date", "default": true },
    { "type": "checkbox", "id": "show_author", "label": "Show author", "default": true },
    { "type": "checkbox", "id": "show_excerpt", "label": "Show excerpt", "default": true },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [{ "name": "Blog Grid" }]
}
{% endschema %}
