{%- comment -%} Reviews Testimonials — Inverted dark section with 3-column testimonials {%- endcomment -%}

<section style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;" data-reveal>
  <div class="page-width">
    <div style="text-align: center; margin-bottom: 40px;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow" style="color: {{ section.settings.text_color }};">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="heading-lg" style="color: {{ section.settings.text_color }};">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <em class="heading-accent">{{ section.settings.heading_accent }}</em>
        {%- endif -%}
      </h2>
    </div>

    <div class="reviews__grid" data-reveal-stagger>
      {%- for block in section.blocks -%}
        <div class="reviews__card" {{ block.shopify_attributes }}>
          <div class="reviews__stars" style="margin-bottom: 20px;">
            {%- assign stars = block.settings.stars | default: 5 -%}
            {%- for i in (1..stars) -%}
              <span style="color: var(--color-primary); display: inline-block; width: 16px; height: 16px;">{% render 'icon', name: 'star' %}</span>
            {%- endfor -%}
          </div>
          <blockquote class="reviews__quote">
            {{ block.settings.quote }}
          </blockquote>
          <div class="reviews__author" style="margin-top: 20px;">
            <p class="font-label" style="font-size: 11px;">{{ block.settings.author_name }}</p>
            {%- if block.settings.author_role != blank -%}
              <p style="font-size: 10px; opacity: 0.7; margin-top: 4px;">{{ block.settings.author_role }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .reviews__grid { display: grid; grid-template-columns: 1fr; gap: 24px; }
  .reviews__card { padding: 32px; border: 1px solid rgba(255,255,255,0.15); }
  .reviews__quote { font-family: var(--font-serif-editorial); font-style: italic; font-size: 20px; line-height: 1.375; }
  .reviews__stars svg { width: 16px; height: 16px; }
  @media (min-width: 768px) {
    .reviews__grid { grid-template-columns: repeat(3, 1fr); gap: 32px; }
    .reviews__quote { font-size: 24px; }
  }
</style>

{% schema %}
{
  "name": "Reviews / Testimonials",
  "tag": "section",
  "class": "reviews-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Testimonials" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "Clients Say" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#1A1714" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "These extensions blend so seamlessly — I get compliments every single day. Absolutely worth the investment." },
        { "type": "text", "id": "author_name", "label": "Author name", "default": "Sarah M." },
        { "type": "text", "id": "author_role", "label": "Author role / location", "default": "Verified Buyer" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Reviews / Testimonials",
      "blocks": [
        { "type": "review", "settings": { "stars": 5, "quote": "These extensions blend so seamlessly — I get compliments every single day. Absolutely worth the investment.", "author_name": "Sarah M.", "author_role": "Verified Buyer" } },
        { "type": "review", "settings": { "stars": 5, "quote": "The lip kit formula is incredible. Long-lasting, hydrating, and the shade range is chef's kiss.", "author_name": "Amara J.", "author_role": "Verified Buyer" } },
        { "type": "review", "settings": { "stars": 5, "quote": "Finally a beauty brand that understands luxury without the pretension. The quality speaks for itself.", "author_name": "Priya K.", "author_role": "Verified Buyer" } }
      ]
    }
  ]
}
{% endschema %}
