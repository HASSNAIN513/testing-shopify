{%- comment -%} Reviews Section {%- endcomment -%}

<section style="background:var(--color-foreground);color:var(--color-background);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow" style="text-align:center;color:var(--color-primary);">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 class="heading-lg" style="text-align:center;margin-bottom:48px;color:var(--color-background);">
      {{ section.settings.heading }}
      {%- if section.settings.heading_accent != blank -%}
        <em class="heading-accent">{{ section.settings.heading_accent }}</em>
      {%- endif -%}
    </h2>
    <div style="display:grid;grid-template-columns:1fr;gap:28px;">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }} style="border:1px solid rgba(255,255,255,0.15);padding:32px;">
          <div style="color:var(--color-primary);margin-bottom:16px;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <blockquote style="font-family:var(--font-serif-editorial);font-size:20px;font-style:italic;line-height:1.4;">{{ block.settings.quote }}</blockquote>
          <p style="font-family:var(--font-label);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;margin-top:20px;">{{ block.settings.author_name }}</p>
          {%- if block.settings.author_role != blank -%}
            <p style="font-size:10px;opacity:0.7;margin-top:4px;">{{ block.settings.author_role }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  @media (min-width: 768px) {
    section[style*="color-foreground"] .page-width > div[style*="grid"] { grid-template-columns: repeat(3, 1fr) !important; }
  }
</style>

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Testimonials" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent", "default": "Say" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "quote", "label": "Quote", "default": "Absolutely love these extensions! They blend perfectly." },
        { "type": "text", "id": "author_name", "label": "Author name", "default": "Sarah M." },
        { "type": "text", "id": "author_role", "label": "Author role", "default": "Verified Buyer" }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
