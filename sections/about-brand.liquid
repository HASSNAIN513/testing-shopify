{%- comment -%} About Brand Section {%- endcomment -%}

<section style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="page-width" style="max-width:768px;margin:0 auto;text-align:center;">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 class="heading-lg" style="margin-top:16px;">
      {{ section.settings.heading }}
      {%- if section.settings.heading_accent != blank -%}
        <em class="heading-accent">{{ section.settings.heading_accent }}</em>
      {%- endif -%}
    </h2>
    {%- if section.settings.body != blank -%}
      <div style="color:var(--color-muted-foreground);margin-top:24px;line-height:1.625;">{{ section.settings.body }}</div>
    {%- endif -%}
    {%- if section.settings.signature_text != blank -%}
      <p style="font-family:var(--font-serif-editorial);font-style:italic;font-size:24px;margin-top:32px;">{{ section.settings.signature_text }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "About Brand",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beauty Without" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent", "default": "Compromise" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>We believe in beauty that empowers. Every product is crafted with care, using ethically sourced ingredients.</p>" },
    { "type": "text", "id": "signature_text", "label": "Signature", "default": "With love, Iymnn" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 96 }
  ]
}
{% endschema %}
