{%- comment -%} About Brand — Centered text section with founder signature {%- endcomment -%}

<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;" data-reveal>
  <div class="page-width">
    <div style="max-width: 768px; margin: 0 auto; text-align: center;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="heading-lg" style="line-height: 1.02;">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <em class="heading-accent">{{ section.settings.heading_accent }}</em>
        {%- endif -%}
      </h2>
      {%- if section.settings.body != blank -%}
        <div class="text-muted" style="margin-top: 24px; line-height: 1.625; font-size: 16px;">
          {{ section.settings.body }}
        </div>
      {%- endif -%}
      {%- if section.settings.signature_text != blank -%}
        <p style="font-family: var(--font-serif-editorial); font-style: italic; font-size: 24px; margin-top: 32px; color: var(--color-foreground);">
          {{ section.settings.signature_text }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Brand",
  "tag": "section",
  "class": "about-brand-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Philosophy" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Beauty Is" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "Personal" },
    { "type": "richtext", "id": "body", "label": "Body text", "default": "<p>At IYMNN BEAUTY, we believe beauty is not one-size-fits-all. Our curated collection is designed to enhance your natural beauty, celebrate your individuality, and make every day feel like a special occasion.</p>" },
    { "type": "text", "id": "signature_text", "label": "Founder signature", "default": "— With love, The IYMNN BEAUTY Team" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 96 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 96 }
  ],
  "presets": [{ "name": "About Brand" }]
}
{% endschema %}
