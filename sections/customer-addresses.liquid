{%- comment -%} Customer Addresses {%- endcomment -%}

<section class="account-dashboard">
  <a href="{{ routes.account_url }}" style="display: inline-flex; align-items: center; gap: 8px; font-family: var(--font-label); font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; margin-bottom: 24px; color: var(--color-muted-foreground);">← {{ 'customer.back_to_account' | t | default: 'Back to Account' }}</a>

  <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 32px;">
    <h1 class="account-dashboard__title">{{ 'customer.addresses' | t | default: 'Addresses' }}</h1>
    <button type="button" class="btn btn--primary" onclick="document.getElementById('new-address-form').style.display = 'block'; this.style.display = 'none';" style="padding: 10px 20px; font-size: 10px;">{{ 'customer.add_address' | t | default: 'Add New Address' }}</button>
  </div>

  {%- comment -%} New Address Form {%- endcomment -%}
  <div id="new-address-form" style="display: none; margin-bottom: 40px; padding: 32px; border: 1px solid var(--color-border);">
    <h2 class="heading-sm" style="margin-bottom: 20px;">{{ 'customer.add_address' | t | default: 'Add New Address' }}</h2>
    {% form 'customer_address', customer.new_address %}
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label class="form-label" for="address-first-name">{{ 'customer.first_name' | t | default: 'First name' }}</label>
          <input type="text" id="address-first-name" name="address[first_name]" class="form-input" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="address-last-name">{{ 'customer.last_name' | t | default: 'Last name' }}</label>
          <input type="text" id="address-last-name" name="address[last_name]" class="form-input" required>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="address-address1">{{ 'customer.address1' | t | default: 'Address' }}</label>
        <input type="text" id="address-address1" name="address[address1]" class="form-input" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="address-address2">{{ 'customer.address2' | t | default: 'Apartment, suite, etc.' }}</label>
        <input type="text" id="address-address2" name="address[address2]" class="form-input">
      </div>
      <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px;">
        <div class="form-group">
          <label class="form-label" for="address-city">{{ 'customer.city' | t | default: 'City' }}</label>
          <input type="text" id="address-city" name="address[city]" class="form-input" required>
        </div>
        <div class="form-group">
          <label class="form-label" for="address-province">{{ 'customer.province' | t | default: 'State / Province' }}</label>
          <input type="text" id="address-province" name="address[province]" class="form-input">
        </div>
        <div class="form-group">
          <label class="form-label" for="address-zip">{{ 'customer.zip' | t | default: 'Zip / Postal code' }}</label>
          <input type="text" id="address-zip" name="address[zip]" class="form-input" required>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="address-country">{{ 'customer.country' | t | default: 'Country' }}</label>
        <select id="address-country" name="address[country]" class="form-select" data-default="{{ form.country }}">{{ all_country_option_tags }}</select>
      </div>
      <div class="form-group">
        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
          <input type="checkbox" name="address[default]" value="1">
          <span class="font-label" style="font-size: 11px;">{{ 'customer.set_default' | t | default: 'Set as default address' }}</span>
        </label>
      </div>
      <div style="display: flex; gap: 12px;">
        <button type="submit" class="btn btn--primary">{{ 'customer.save_address' | t | default: 'Save Address' }}</button>
        <button type="button" class="btn btn--outline" onclick="document.getElementById('new-address-form').style.display = 'none';">{{ 'general.cancel' | t | default: 'Cancel' }}</button>
      </div>
    {% endform %}
  </div>

  {%- comment -%} Existing Addresses {%- endcomment -%}
  <div style="display: grid; grid-template-columns: 1fr; gap: 20px;">
    {%- for address in customer.addresses -%}
      <div style="padding: 24px; border: 1px solid var(--color-border);{% if address == customer.default_address %} border-color: var(--color-primary);{% endif %}">
        {%- if address == customer.default_address -%}
          <span class="badge badge--bestseller" style="margin-bottom: 12px;">{{ 'customer.default_address' | t | default: 'Default' }}</span>
        {%- endif -%}
        <p style="line-height: 1.625;">{{ address | format_address }}</p>
        <div style="display: flex; gap: 12px; margin-top: 16px;">
          <a href="{{ routes.account_addresses_url }}/{{ address.id }}/edit" class="btn btn--outline" style="padding: 8px 16px; font-size: 10px;">{{ 'customer.edit_address' | t | default: 'Edit' }}</a>
          <button type="button" class="btn btn--outline" style="padding: 8px 16px; font-size: 10px; color: var(--color-destructive); border-color: var(--color-destructive);" onclick="if(confirm('{{ 'customer.confirm_delete' | t | default: 'Are you sure?' }}')) { Shopify.postLink('{{ routes.account_addresses_url }}/{{ address.id }}', { parameters: { _method: 'delete' } }); }">{{ 'customer.delete_address' | t | default: 'Delete' }}</button>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{ "name": "Customer Addresses", "tag": "section", "settings": [], "presets": [{ "name": "Customer Addresses" }] }
{% endschema %}
