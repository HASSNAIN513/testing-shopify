{%- comment -%} Instagram Grid — 6-tile grid with hover overlay {%- endcomment -%}

<section style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;" data-reveal>
  <div class="page-width">
    <div style="text-align: center; margin-bottom: 40px;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="heading-lg">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <em class="heading-accent">{{ section.settings.heading_accent }}</em>
        {%- endif -%}
      </h2>
      {%- if section.settings.instagram_handle != blank -%}
        <p class="font-label" style="font-size: 11px; margin-top: 12px; color: var(--color-muted-foreground);">
          <a href="{{ section.settings.cta_url | default: '#' }}" style="transition: color 0.2s;" target="_blank" rel="noopener noreferrer">{{ section.settings.instagram_handle }}</a>
        </p>
      {%- endif -%}
    </div>

    <div class="instagram__grid" data-reveal-stagger>
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link_url | default: section.settings.cta_url | default: '#' }}" class="instagram__tile" {{ block.shopify_attributes }} target="_blank" rel="noopener noreferrer" aria-label="Instagram post {{ forloop.index }}">
          {%- if block.settings.image -%}
            <img
              src="{{ block.settings.image | image_url: width: 400 }}"
              srcset="{{ block.settings.image | image_url: width: 200 }} 200w, {{ block.settings.image | image_url: width: 300 }} 300w, {{ block.settings.image | image_url: width: 400 }} 400w"
              sizes="(min-width: 1024px) 16vw, (min-width: 640px) 33vw, 50vw"
              alt="Instagram post {{ forloop.index }}"
              loading="lazy"
              class="instagram__image"
            >
          {%- endif -%}
          <div class="instagram__overlay">
            <span class="instagram__icon">{% render 'icon', name: 'instagram' %}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .instagram__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .instagram__tile { position: relative; overflow: hidden; aspect-ratio: 1 / 1; display: block; }
  .instagram__image { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s ease-out; }
  .instagram__tile:hover .instagram__image { transform: scale(1.1); }
  .instagram__overlay { position: absolute; inset: 0; background: rgba(200, 75, 106, 0); display: flex; align-items: center; justify-content: center; transition: background-color 0.3s; }
  .instagram__tile:hover .instagram__overlay { background: rgba(200, 75, 106, 0.6); }
  .instagram__icon { color: #fff; opacity: 0; transition: opacity 0.3s; }
  .instagram__icon svg { width: 28px; height: 28px; }
  .instagram__tile:hover .instagram__icon { opacity: 1; }
  @media (min-width: 640px) { .instagram__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .instagram__grid { grid-template-columns: repeat(6, 1fr); gap: 12px; } }
</style>

{% schema %}
{
  "name": "Instagram Grid",
  "tag": "section",
  "class": "instagram-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Follow Along" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "On" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "Instagram" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram handle", "default": "@iymmn.beauty" },
    { "type": "url", "id": "cta_url", "label": "Instagram profile URL" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#FBF0ED" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Instagram Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Instagram Grid",
      "blocks": [
        { "type": "tile" }, { "type": "tile" }, { "type": "tile" },
        { "type": "tile" }, { "type": "tile" }, { "type": "tile" }
      ]
    }
  ]
}
{% endschema %}
