{%- comment -%} Instagram Grid Section {%- endcomment -%}

<section style="background:var(--color-blush);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="page-width" style="text-align:center;">
    <h2 class="heading-lg" style="margin-bottom:8px;">{{ section.settings.heading | default: 'Follow Along' }}</h2>
    {%- if section.settings.instagram_handle != blank -%}
      <p style="color:var(--color-primary);font-family:var(--font-label);font-size:12px;letter-spacing:0.1em;margin-bottom:40px;">{{ section.settings.instagram_handle }}</p>
    {%- endif -%}
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;">
      {%- for block in section.blocks -%}
        <div {{ block.shopify_attributes }} style="aspect-ratio:1/1;overflow:hidden;position:relative;">
          {%- if block.settings.image -%}
            <img src="{{ block.settings.image | image_url: width: 400 }}" alt="Instagram" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
          {%- else -%}
            <div style="width:100%;height:100%;background:var(--color-accent);"></div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.cta_url != blank -%}
      <a href="{{ section.settings.cta_url }}" style="display:inline-block;margin-top:32px;font-family:var(--font-label);font-size:12px;letter-spacing:0.12em;text-transform:uppercase;">Follow Us</a>
    {%- endif -%}
  </div>
</section>

<style>
  @media (min-width: 640px) {
    section[style*="color-blush"] .page-width > div[style*="repeat(2"] { grid-template-columns: repeat(3, 1fr) !important; }
  }
  @media (min-width: 1024px) {
    section[style*="color-blush"] .page-width > div[style*="repeat(2"] { grid-template-columns: repeat(6, 1fr) !important; gap: 12px; }
  }
</style>

{% schema %}
{
  "name": "Instagram Grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Follow Along" },
    { "type": "text", "id": "instagram_handle", "label": "Instagram handle", "default": "@iymmn.beauty" },
    { "type": "url", "id": "cta_url", "label": "Instagram URL" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "max_blocks": 8
}
{% endschema %}
