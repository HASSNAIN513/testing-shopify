{%- comment -%} 404 Page {%- endcomment -%}

<section class="four-oh-four section-padding">
  <div class="page-width">
    <p class="four-oh-four__number">404</p>
    <h1 class="four-oh-four__heading">{{ section.settings.heading | default: 'Page Not Found' }}</h1>
    <p class="four-oh-four__text">{{ section.settings.subtext | default: 'The page you are looking for might have been removed, renamed, or is temporarily unavailable.' }}</p>
    <div class="four-oh-four__actions">
      {% render 'button', label: 'Back to Home', url: '/', style: 'primary', icon: 'arrow' %}
      {%- if section.settings.cta_label != blank -%}
        {% render 'button', label: section.settings.cta_label, url: section.settings.cta_url, style: 'outline', icon: 'arrow' %}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "404 Page",
  "tag": "section",
  "class": "four-oh-four-section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Page Not Found" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "The page you are looking for might have been removed, renamed, or is temporarily unavailable." },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop Collections" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "404 Page" }]
}
{% endschema %}
