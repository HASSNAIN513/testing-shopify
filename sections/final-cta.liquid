{%- comment -%} Final CTA / Newsletter Section {%- endcomment -%}

<section style="background:var(--color-primary);color:var(--color-primary-foreground);padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="page-width" style="max-width:768px;margin:0 auto;text-align:center;">
    {%- if section.settings.eyebrow != blank -%}
      <p style="font-family:var(--font-label);font-size:11px;letter-spacing:0.18em;text-transform:uppercase;opacity:0.8;">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 style="font-family:var(--font-display);font-size:36px;margin-top:16px;">
      {{ section.settings.heading }}
      {%- if section.settings.heading_accent != blank -%}
        <em class="heading-accent" style="color:var(--color-primary-foreground);">{{ section.settings.heading_accent }}</em>
      {%- endif -%}
    </h2>
    {%- if section.settings.body != blank -%}
      <p style="opacity:0.85;margin-top:16px;line-height:1.625;">{{ section.settings.body }}</p>
    {%- endif -%}
    <form method="post" action="/contact#newsletter" class="newsletter-form" style="display:flex;gap:0;margin-top:32px;max-width:480px;margin-left:auto;margin-right:auto;">
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="utf8" value="&#x2713;">
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}" required style="flex:1;padding:14px 20px;border:1px solid rgba(255,255,255,0.3);background:transparent;color:inherit;font-size:14px;">
      <button type="submit" style="padding:14px 28px;background:var(--color-foreground);color:var(--color-background);border:none;font-family:var(--font-label);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;">{{ section.settings.button_text | default: 'Subscribe' }}</button>
    </form>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter CTA",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join The Glow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 15% Off Your" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent", "default": "First Order" },
    { "type": "text", "id": "body", "label": "Body", "default": "Subscribe to our newsletter for exclusive offers, beauty tips, and early access to new collections." },
    { "type": "text", "id": "placeholder", "label": "Email placeholder", "default": "Enter your email" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Subscribe" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ]
}
{% endschema %}
