{%- comment -%} Final CTA — Newsletter signup on primary background with watermark {%- endcomment -%}

<section style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; position: relative; overflow: hidden;" data-reveal>
  {%- comment -%} Decorative watermark G {%- endcomment -%}
  {%- if section.settings.decorative_letter != blank -%}
    <span class="final-cta__watermark" aria-hidden="true">{{ section.settings.decorative_letter }}</span>
  {%- endif -%}

  <div class="page-width" style="position: relative; z-index: 1;">
    <div style="max-width: 768px; margin: 0 auto; text-align: center;">
      {%- if section.settings.eyebrow != blank -%}
        <p class="font-label" style="font-size: 11px; opacity: 0.8; margin-bottom: 16px; color: {{ section.settings.text_color }};">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 style="font-family: var(--font-display); font-size: 36px; letter-spacing: -0.02em; line-height: 1; color: {{ section.settings.text_color }};">
        {{ section.settings.heading }}
        {%- if section.settings.heading_accent != blank -%}
          <em class="heading-accent" style="color: {{ section.settings.text_color }};">{{ section.settings.heading_accent }}</em>
        {%- endif -%}
      </h2>
      {%- if section.settings.description != blank -%}
        <p style="margin-top: 16px; opacity: 0.85; max-width: 448px; margin-left: auto; margin-right: auto; line-height: 1.625; color: {{ section.settings.text_color }};">{{ section.settings.description }}</p>
      {%- endif -%}
      <div style="max-width: 448px; margin: 32px auto 0;">
        {% render 'newsletter-form', inverted: true, placeholder_text: section.settings.form_placeholder, button_text: section.settings.button_text %}
      </div>
      {%- if section.settings.disclaimer != blank -%}
        <p style="font-size: 10px; opacity: 0.7; margin-top: 16px; color: {{ section.settings.text_color }};">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .final-cta__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-serif-editorial);
    font-style: italic;
    font-size: 28vw;
    line-height: 1;
    opacity: 0.1;
    pointer-events: none;
    user-select: none;
    color: inherit;
  }
  @media (min-width: 1024px) {
    .final-cta__watermark + .page-width h2 { font-size: 64px; }
  }
</style>

{% schema %}
{
  "name": "Final CTA / Newsletter",
  "tag": "section",
  "class": "final-cta-section",
  "settings": [
    { "type": "text", "id": "decorative_letter", "label": "Decorative letter", "default": "G" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Join the Glow" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay In The" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "Glow" },
    { "type": "text", "id": "description", "label": "Description", "default": "Subscribe for exclusive offers, new arrivals, and beauty tips delivered to your inbox." },
    { "type": "text", "id": "form_placeholder", "label": "Form placeholder", "default": "Enter your email" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Subscribe" },
    { "type": "text", "id": "disclaimer", "label": "Disclaimer text", "default": "By subscribing, you agree to our Privacy Policy. Unsubscribe anytime." },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#C84B6A" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#FFFFFF" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [{ "name": "Final CTA / Newsletter" }]
}
{% endschema %}
