{%- comment -%} Best Sellers — Product grid section {%- endcomment -%}

<section style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px; border-top: 1px solid var(--color-border);" data-reveal>
  <div class="page-width">
    {%- comment -%} Section Header {%- endcomment -%}
    <div style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 40px;">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="heading-lg">
          {{ section.settings.heading }}
          {%- if section.settings.heading_accent != blank -%}
            <em class="heading-accent">{{ section.settings.heading_accent }}</em>
          {%- endif -%}
        </h2>
      </div>
      {%- if section.settings.show_view_all and section.settings.view_all_url != blank -%}
        <a href="{{ section.settings.view_all_url }}" class="font-label" style="font-size: 11px; color: var(--color-foreground); text-decoration: underline; text-underline-offset: 4px; transition: color 0.2s; display: none;">
          {{ section.settings.view_all_text | default: 'Shop all' }}
          <span style="display: inline-block; transition: transform 0.2s;">&rarr;</span>
        </a>
      {%- endif -%}
    </div>

    {%- comment -%} Product Grid {%- endcomment -%}
    <div class="product-grid" data-reveal-stagger>
      {%- assign collection = collections[section.settings.collection] -%}
      {%- assign products_to_show = section.settings.products_to_show | default: 4 -%}
      {%- if collection != blank -%}
        {%- for product in collection.products limit: products_to_show -%}
          {% render 'product-card', product: product, show_quick_add: true, show_swatches: true, show_badge: true, lazy: true %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          <div class="product-card">
            <div class="product-card__image-wrap" style="background: var(--color-secondary);"></div>
            <div class="product-card__info">
              <div class="product-card__tag">Collection</div>
              <h3 class="product-card__name"><a href="#">Sample Product {{ i }}</a></h3>
              <div class="product-card__price"><span>{{ 2900 | money }}</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and section.settings.view_all_url != blank -%}
      <div style="text-align: center; margin-top: 40px;">
        {% render 'button', label: section.settings.view_all_text, url: section.settings.view_all_url, style: 'outline', icon: 'arrow' %}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .best-sellers__view-all-desktop { display: inline !important; }
  }
  @media (min-width: 1024px) {
    .best-sellers__header { margin-bottom: 56px; }
  }
</style>

{% schema %}
{
  "name": "Best Sellers",
  "tag": "section",
  "class": "best-sellers-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Curated for You" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (italic)", "default": "Sellers" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "show_view_all", "label": "Show 'View All' link", "default": true },
    { "type": "text", "id": "view_all_text", "label": "View all text", "default": "Shop all" },
    { "type": "url", "id": "view_all_url", "label": "View all link" },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 150, "step": 4, "unit": "px", "default": 80 }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}
