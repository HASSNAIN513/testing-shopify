  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Heading Font"
      },
      {
        "type": "font_picker",
        "id": "type_header_font",
        "label": "Heading Font",
        "default": "playfair_display_n4",
        "info": "Used for headings, prices, logo, product names"
      },
      {
        "type": "select",
        "id": "heading_text_transform",
        "label": "Heading Text Transform",
        "options": [
          { "value": "none", "label": "None" },
