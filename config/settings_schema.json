      {
        "type": "range",
        "id": "label_letter_spacing",
        "label": "Label Letter Spacing",
        "min": 0,
        "max": 30,
        "step": 1,
        "unit": "%",
        "default": 18,
        "info": "Default is 0.18em for Montserrat labels"
      }
    ]
  },
