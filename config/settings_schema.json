          { "value": "capitalize", "label": "Capitalize" }
        ],
        "default": "none"
      },
      {
        "type": "range",
        "id": "heading_letter_spacing",
        "label": "Heading Letter Spacing",
        "min": -5,
        "max": 5,
        "step": 1,
        "unit": "%",
        "default": -2,
        "info": "Default is -0.02em for editorial style"
      },
      {
        "type": "header",
        "content": "Body Font"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "label": "Body Font",
        "default": "inter_n4",
        "info": "Used for body text, paragraphs"
      },
      {
        "type": "range",
        "id": "type_body_size",
        "label": "Base Font Size",
        "min": 14,
        "max": 20,
        "step": 1,
        "unit": "px",
        "default": 16
      },
      {
        "type": "header",
        "content": "Label Font"
      },
      {
        "type": "select",
        "id": "label_text_transform",
        "label": "Label Text Transform",
        "options": [
          { "value": "none", "label": "None" },
          { "value": "uppercase", "label": "Uppercase" }
