{%- comment -%}
  Renders social media icon links from theme settings.
  Usage: {% render 'social-links' %}
{%- endcomment -%}

{%- liquid
  assign has_social = false
  if settings.social_instagram != blank or settings.social_tiktok != blank or settings.social_pinterest != blank or settings.social_facebook != blank or settings.social_youtube != blank or settings.social_twitter != blank
    assign has_social = true
  endif
-%}

{%- if has_social -%}
  <div class="social-links" aria-label="{{ 'general.social_media' | t | default: 'Social media' }}">
    {%- if settings.social_instagram != blank -%}
      <a href="{{ settings.social_instagram }}" class="social-links__item" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        {% render 'icon', name: 'instagram' %}
      </a>
    {%- endif -%}
    {%- if settings.social_tiktok != blank -%}
      <a href="{{ settings.social_tiktok }}" class="social-links__item" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
        {% render 'icon', name: 'tiktok' %}
      </a>
    {%- endif -%}
    {%- if settings.social_pinterest != blank -%}
      <a href="{{ settings.social_pinterest }}" class="social-links__item" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">
        {% render 'icon', name: 'pinterest' %}
      </a>
    {%- endif -%}
    {%- if settings.social_facebook != blank -%}
      <a href="{{ settings.social_facebook }}" class="social-links__item" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        {% render 'icon', name: 'facebook' %}
      </a>
    {%- endif -%}
    {%- if settings.social_youtube != blank -%}
      <a href="{{ settings.social_youtube }}" class="social-links__item" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
        {% render 'icon', name: 'youtube' %}
      </a>
    {%- endif -%}
    {%- if settings.social_twitter != blank -%}
      <a href="{{ settings.social_twitter }}" class="social-links__item" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
        {% render 'icon', name: 'twitter' %}
      </a>
    {%- endif -%}
  </div>
{%- endif -%}
