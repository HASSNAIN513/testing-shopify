{%- comment -%}
  Renders a reusable button.
  Usage: {% render 'button', label: 'Shop Now', url: '/collections/all', style: 'primary' %}
  Accepts: label, url, style ('primary'|'secondary'|'outline'|'outline-light'), full_width (boolean), icon ('arrow'|'none'), tag ('a'|'button'), type, class_extra
{%- endcomment -%}

{%- liquid
  assign btn_style = style | default: 'primary'
  assign btn_tag = tag | default: 'a'
  assign btn_icon = icon | default: 'arrow'
  assign btn_class = 'btn btn--' | append: btn_style
  if full_width
    assign btn_class = btn_class | append: ' btn--full'
  endif
  if class_extra
    assign btn_class = btn_class | append: ' ' | append: class_extra
  endif
-%}

{%- if btn_tag == 'a' -%}
  <a href="{{ url }}" class="{{ btn_class }}" {% if aria_label %}aria-label="{{ aria_label }}"{% endif %}>
    <span>{{ label }}</span>
    {%- if btn_icon == 'arrow' -%}
      <span class="btn__icon btn__icon--arrow">{% render 'icon', name: 'arrow-up-right' %}</span>
    {%- endif -%}
  </a>
{%- else -%}
  <button type="{{ type | default: 'submit' }}" class="{{ btn_class }}" {% if name %}name="{{ name }}"{% endif %} {% if value %}value="{{ value }}"{% endif %} {% if disabled %}disabled{% endif %} {% if aria_label %}aria-label="{{ aria_label }}"{% endif %}>
    <span>{{ label }}</span>
    {%- if btn_icon == 'arrow' -%}
      <span class="btn__icon btn__icon--arrow">{% render 'icon', name: 'arrow-up-right' %}</span>
    {%- endif -%}
  </button>
{%- endif -%}
