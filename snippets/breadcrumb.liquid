{%- comment -%}
  Renders breadcrumb navigation.
  Usage: {% render 'breadcrumb' %}
  Auto-generates path from current template context.
{%- endcomment -%}

<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="/">{{ 'general.home' | t | default: 'Home' }}</a>

  {%- if template.name == 'product' -%}
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    {%- if product.collections.size > 0 -%}
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
      <span class="breadcrumb__separator" aria-hidden="true">/</span>
    {%- endif -%}
    <span aria-current="page">{{ product.title }}</span>

  {%- elsif template.name == 'collection' -%}
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    {%- if current_tags -%}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span class="breadcrumb__separator" aria-hidden="true">/</span>
      <span aria-current="page">{{ current_tags | join: ' + ' }}</span>
    {%- else -%}
      <span aria-current="page">{{ collection.title }}</span>
    {%- endif -%}

  {%- elsif template.name == 'blog' -%}
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    <span aria-current="page">{{ blog.title }}</span>

  {%- elsif template.name == 'article' -%}
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    <a href="{{ blog.url }}">{{ blog.title }}</a>
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    <span aria-current="page">{{ article.title }}</span>

  {%- elsif template.name == 'page' -%}
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    <span aria-current="page">{{ page.title }}</span>

  {%- elsif template.name == 'search' -%}
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    <span aria-current="page">{{ 'general.search' | t | default: 'Search' }}</span>

  {%- elsif template.name == 'cart' -%}
    <span class="breadcrumb__separator" aria-hidden="true">/</span>
    <span aria-current="page">{{ 'cart.title' | t | default: 'Cart' }}</span>
  {%- endif -%}
</nav>
