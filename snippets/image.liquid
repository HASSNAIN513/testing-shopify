{%- comment -%}
  Renders a responsive image with lazy loading and srcset.
  Usage: {% render 'image', image: product.featured_image, alt: product.title, sizes: '(min-width: 1024px) 25vw, 50vw', width: 800 %}
  Accepts: image, alt, sizes, width, aspect_ratio, lazy (default true), class
{%- endcomment -%}

{%- liquid
  assign lazy = lazy | default: true
  assign loading = 'lazy'
  assign fetchpriority = 'auto'
  if lazy == false
    assign loading = 'eager'
    assign fetchpriority = 'high'
  endif
  assign width = width | default: 800
  assign alt_text = alt | default: image.alt | default: ''
  assign sizes_attr = sizes | default: '(min-width: 1024px) 25vw, 50vw'
  assign image_class = class | default: ''
-%}

{%- if image != blank -%}
  <img
    src="{{ image | image_url: width: width }}"
    srcset="
      {{ image | image_url: width: 200 }} 200w,
      {{ image | image_url: width: 400 }} 400w,
      {{ image | image_url: width: 600 }} 600w,
      {{ image | image_url: width: 800 }} 800w,
      {{ image | image_url: width: 1000 }} 1000w,
      {{ image | image_url: width: 1200 }} 1200w
    "
    sizes="{{ sizes_attr }}"
    alt="{{ alt_text | escape }}"
    loading="{{ loading }}"
    fetchpriority="{{ fetchpriority }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    {%- if image_class != blank %} class="{{ image_class }}"{% endif -%}
    {%- if aspect_ratio %} style="aspect-ratio: {{ aspect_ratio }}; object-fit: cover;"{% endif -%}
  >
{%- else -%}
  <div class="image-placeholder" {% if aspect_ratio %}style="aspect-ratio: {{ aspect_ratio }};"{% endif %}>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="width: 48px; height: 48px; opacity: 0.3;">
      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
      <circle cx="9" cy="9" r="2"></circle>
      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
    </svg>
  </div>
{%- endif -%}
